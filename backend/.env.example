# ── Core ────────────────────────────────────────────────────────────────
# Supabase Postgres (use the connection pooler URL, asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pulseai
REDIS_URL=redis://:changeme@localhost:6379/0
SECRET_KEY=change-me-to-a-long-random-string

# Super admin bootstrap (first boot only)
SUPER_ADMIN_EMAIL=admin@infobeans.com
SUPER_ADMIN_PASSWORD=changeme-super
SEED_DEMO_DATA=true

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# ── LLM (Groq via LiteLLM) ──────────────────────────────────────────────
GROQ_API_KEY=
LLM_MODEL_ANALYSIS=groq/llama-3.3-70b-versatile
LLM_MODEL_CHAT=groq/llama-3.1-8b-instant
LLM_MODEL_JUDGE=groq/llama-3.3-70b-versatile

# ── Supabase Storage (document uploads) ─────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=pulseai-documents

# ── Jira (real connector) — token read from a secret_ref env var ────────
# e.g. JIRA_TOKEN_ATLAS=<atlassian-api-token>; connector.secret_ref = "JIRA_TOKEN_ATLAS"
